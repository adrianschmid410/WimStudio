<Window x:Class="WimStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WimStudio.ViewModels"
        xmlns:helpers="clr-namespace:WimStudio.Helpers"
        Title="WIM Studio - Windows Imaging Format Editor"
        Height="780" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Window.Resources>
    <helpers:InverseBooleanConverter x:Key="InverseBoolConverter"/>
  </Window.Resources>

  <DockPanel>

    <!-- Administrator-Warnung -->
    <Border DockPanel.Dock="Top"
                Background="#FFE4B5"
                BorderBrush="#D2691E"
                BorderThickness="0,0,0,1"
                Padding="10,6">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <TextBlock Text="⚠ Anwendung läuft ohne Administratorrechte. WIM-Operationen werden fehlschlagen. Bitte als Administrator neu starten."
                       FontWeight="SemiBold"/>
    </Border>

    <!-- Statusleiste -->
    <StatusBar DockPanel.Dock="Bottom" Height="28">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusText}"/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <ProgressBar Width="200" Height="14"
                             Value="{Binding Progress}"
                             Maximum="100">
          <ProgressBar.Style>
            <Style TargetType="ProgressBar">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ProgressBar.Style>
        </ProgressBar>
      </StatusBarItem>
      <StatusBarItem>
        <TextBlock Text="{Binding Progress, StringFormat={}{0}%}">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StatusBarItem>
    </StatusBar>

    <!-- Hauptbereich -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="400"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="3*" MinWidth="450"/>
      </Grid.ColumnDefinitions>

      <!-- Linke Spalte: Eingaben -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="6">

          <!-- Quelle & Ziel -->
          <GroupBox Header="Quelle und Ziel">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>

              <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Quellverzeichnis (zu erfassende Daten):"/>
              <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}"/>
              <Button Grid.Row="1" Grid.Column="1" Content="Durchsuchen..." Command="{Binding BrowseSourceDirectoryCommand}"/>

              <Label Grid.Row="2" Grid.ColumnSpan="2" Content="WIM-Zieldatei:"/>
              <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding WimFilePath, UpdateSourceTrigger=PropertyChanged}"/>
              <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <Button Content="Neu..." Command="{Binding BrowseWimSaveCommand}"/>
                <Button Content="Öffnen..." Command="{Binding BrowseWimOpenCommand}"/>
              </StackPanel>
            </Grid>
          </GroupBox>

          <!-- Image-Metadaten -->
          <GroupBox Header="Image-Metadaten">
            <StackPanel>
              <Label Content="Image-Name:"/>
              <TextBox Text="{Binding ImageName, UpdateSourceTrigger=PropertyChanged}"/>

              <Label Content="Beschreibung (optional):"/>
              <TextBox Text="{Binding ImageDescription, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50"/>
            </StackPanel>
          </GroupBox>

          <!-- Optionen -->
          <GroupBox Header="Optionen">
            <StackPanel>
              <Label Content="Kompression:"/>
              <ComboBox ItemsSource="{Binding CompressionTypes}"
                                      SelectedItem="{Binding SelectedCompression}"/>

              <CheckBox Content="Datei nach Erstellung verifizieren (/Verify)"
                                      IsChecked="{Binding Verify}" Margin="4,8,4,4"/>
              <CheckBox Content="Als bootfähig markieren (/Bootable, nur für WinPE)"
                                      IsChecked="{Binding Bootable}" Margin="4"/>
            </StackPanel>
          </GroupBox>

          <!-- Hauptaktionen -->
          <GroupBox Header="Aktionen">
            <StackPanel>
              <Button Content="Neue WIM erstellen (Capture)"
                                    Command="{Binding CaptureImageCommand}"
                                    HorizontalAlignment="Stretch" Height="36" FontWeight="SemiBold"/>
              <Button Content="An vorhandene WIM anhängen (Append)"
                                    Command="{Binding AppendImageCommand}"
                                    HorizontalAlignment="Stretch" Height="32"/>
              <Button Content="Image-Infos neu laden"
                                    Command="{Binding LoadImageInfoCommand}"
                                    HorizontalAlignment="Stretch"/>
              <Button Content="Abbrechen"
                                    Command="{Binding CancelCommand}"
                                    HorizontalAlignment="Stretch" Background="#FFE0E0"/>
            </StackPanel>
          </GroupBox>

          <!-- Mount-Operationen -->
          <GroupBox Header="Mount / Bearbeitung">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>

              <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Mount-Verzeichnis (leer):"/>
              <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding MountDirectory, UpdateSourceTrigger=PropertyChanged}"/>
              <Button Grid.Row="1" Grid.Column="1" Content="..." Command="{Binding BrowseMountDirectoryCommand}"/>

              <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Content="Mount" Command="{Binding MountImageCommand}"/>
                <Button Content="Unmount (Commit)" Command="{Binding UnmountImageCommand}" CommandParameter="commit"/>
                <Button Content="Unmount (Discard)" Command="{Binding UnmountImageCommand}" CommandParameter="discard"/>
              </StackPanel>
            </Grid>
          </GroupBox>

        </StackPanel>
      </ScrollViewer>

      <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

      <!-- Rechte Spalte: Image-Liste und Log -->
      <Grid Grid.Column="2" Margin="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="2*" MinHeight="150"/>
          <RowDefinition Height="5"/>
          <RowDefinition Height="3*" MinHeight="150"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Images in der WIM-Datei:"
                           FontWeight="SemiBold" Margin="4,4,4,2"/>

        <Grid Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Images}"
                              SelectedItem="{Binding SelectedImage}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="50"/>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="Architektur" Binding="{Binding Architecture}" Width="100"/>
              <DataGridTextColumn Header="Größe (Bytes)" Binding="{Binding Size, StringFormat=N0}" Width="130"/>
            </DataGrid.Columns>
          </DataGrid>

          <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="Image löschen" Command="{Binding DeleteSelectedImageCommand}"/>
            <Button Content="Image exportieren..." Command="{Binding ExportImageCommand}"/>
          </StackPanel>
        </Grid>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

        <Grid Grid.Row="3">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0" Margin="4,4,4,2">
            <Button DockPanel.Dock="Right" Content="Leeren" Command="{Binding ClearLogCommand}" MinWidth="60"/>
            <TextBlock Text="DISM-Ausgabe / Log:" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </DockPanel>
          <TextBox Grid.Row="1"
                             Text="{Binding LogOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="12"
                             Background="#1E1E1E"
                             Foreground="#DCDCDC"
                             TextWrapping="NoWrap"
                             x:Name="LogTextBox"
                             TextChanged="LogTextBox_TextChanged" Margin="4,4,4,40"/>
          <TextBlock x:Name="Copyright"
           Text="© 2026 Adrian Schmid"
           FontWeight="SemiBold"
           HorizontalAlignment="Right"
           VerticalAlignment="Bottom"
           Margin="0,0,10,10"
           Grid.Row="1"
           Panel.ZIndex="99" />
        </Grid>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
